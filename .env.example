# ====== Polycopy environment ======
# Copy to .env and fill in. Never commit .env.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Username of the bot (no @), used by the web login widget
TELEGRAM_BOT_USERNAME=

# --- Database ---
# Local dev defaults to sqlite. For prod use postgres.
DATABASE_URL=sqlite+aiosqlite:///./polycopy.db
# Example postgres: postgresql+asyncpg://polycopy:polycopy@db:5432/polycopy

# --- Polymarket ---
POLYMARKET_DATA_API=https://data-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_LB_API=https://lb-api.polymarket.com
# Polygon RPC for on-chain reads (optional in v1)
POLYGON_RPC=https://polygon-rpc.com
POLYGON_CHAIN_ID=137

# --- App ---
APP_ENV=dev
APP_SECRET=change-me-to-a-long-random-string
# Global dry-run: when true, NO real orders are placed for anyone (every copy
# is simulated end-to-end). Recommended while validating before going live.
PAPER_TRADING=false
# Used to encrypt per-user CLOB API secrets at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Allowed CORS origins for the API (comma-separated). "*" for dev; set explicit
# origins (e.g. https://app.yourdomain.com) in production.
CORS_ORIGINS=*

# --- Web dashboard (Next.js reads NEXT_PUBLIC_* at build/runtime) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# Bot username (no @) for the Telegram login widget on the dashboard
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# --- Workers ---
# How often (seconds) the trader-watcher polls Polymarket for new trades
WATCHER_POLL_INTERVAL=15
# How often (seconds) the scout rescans the leaderboard
SCOUT_POLL_INTERVAL=3600
# How often (seconds) to reconcile submitted orders against actual fills
RECONCILE_POLL_INTERVAL=30
